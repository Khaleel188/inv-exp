PORT=4000

# --- Local docker (TCP) ---
REDIS_URL=redis://localhost:6379/0

# --- Upstash on Render (required in production) ---
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token
# Vercel/KV aliases also work: KV_REST_API_URL, KV_REST_API_TOKEN
# Or: REDIS_URL=https://your-db.upstash.io + REDIS_TOKEN=your-token

# --- Upstash TCP (optional) ---
# REDIS_URL=rediss://:YOUR_PASSWORD@your-db.upstash.io:6379

REDIS_REALTIME_CHANNEL=inv:realtime
DJANGO_SECRET_KEY=replace-me
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
